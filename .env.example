# Railway asigna PORT automaticamente. Para desarrollo local puedes usar 3000.
PORT=3000

# HiveMQ Cloud normalmente usa MQTT sobre TLS en el puerto 8883.
# Ejemplo: mqtts://xxxxxxxx.s1.eu.hivemq.cloud:8883
MQTT_URL=mqtts://TU_CLUSTER_HIVEMQ:8883
MQTT_USERNAME=TU_USUARIO_HIVEMQ
MQTT_PASSWORD=TU_PASSWORD_HIVEMQ

# Opcional.
MQTT_CLIENT_ID=smarthomeplus-web
MQTT_TOPIC_PREFIX=SmartHomePlus
MQTT_REJECT_UNAUTHORIZED=true

# Si no configuras MQTT_URL, la app entra en modo demo automaticamente.
# Fuerza demo aunque existan credenciales:
DEMO_MODE=false

# La web es solo dashboard. Si mas adelante quieres publicar comandos al broker,
# esto puede activarse en el backend, pero por defecto queda apagado.
ENABLE_CONTROL_PUBLISH=false
